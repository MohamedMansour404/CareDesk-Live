# ============================================
# CareDesk AI – Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/caredesk

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (primary)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct-v0.1

# AI routing
AI_PROVIDER=openrouter
AI_CACHE_TTL_MS=300000

# WebSocket
WS_CORS_ORIGIN=http://localhost:5173

# ============================================
# Production Hardening (NEW)
# ============================================

# Global Rate Limiting (burst)
# Recommended production defaults:
# - 60 requests / second burst per actor (user if authenticated, else IP)
# - 2s temporary block when burst exceeded
RATE_LIMIT_BURST_POINTS=60
RATE_LIMIT_BURST_DURATION_SECONDS=1
RATE_LIMIT_BURST_BLOCK_SECONDS=2

# Global Rate Limiting (sustained)
# Recommended production defaults:
# - 1200 requests / minute per actor
# - 30s block when sustained quota exceeded
RATE_LIMIT_SUSTAINED_POINTS=1200
RATE_LIMIT_SUSTAINED_DURATION_SECONDS=60
RATE_LIMIT_SUSTAINED_BLOCK_SECONDS=30

# Rate limiter backend failure behavior
# true  -> fail closed (recommended in production)
# false -> fail open (recommended only for local/dev)
RATE_LIMIT_FAIL_CLOSED=true

# Express trust proxy setting used for secure req.ip derivation.
# Keep false unless running behind a trusted reverse proxy/load balancer.
# Examples:
# TRUST_PROXY=false
# TRUST_PROXY=true
# TRUST_PROXY=1
# TRUST_PROXY=loopback,linklocal,uniquelocal
TRUST_PROXY=false

# Idempotency consistency mode
# redis-required   -> deterministic cross-instance safety (recommended production)
# best-effort-local -> fallback to local map (local/dev only)
IDEMPOTENCY_MODE=redis-required

# WebSocket allowlist (comma-separated)
# IMPORTANT: keep strict in production (no wildcard)
# Example production:
# WS_CORS_ORIGIN=https://app.example.com,https://ops.example.com

# Logging
LOG_LEVEL=debug
